function generateMigration($name) {
    $datePrefix = date('Y_m_d_His_');
    $className = implode('', array_map('ucfirst', explode('_', $name)));
    $filename = $datePrefix . $name . '.php';
    $path = __DIR__ . "/App/Migrations/" . $filename;
    if (!is_dir(__DIR__ . "/App/Migrations")) @mkdir(__DIR__ . "/App/Migrations", 0777, true);
    $content = "<?php\nnamespace App\Migrations;\n\nclass $className {\n    public function up(\PDO \$db) {\n        // \$db->exec(\"...\");\n    }\n}";
    file_put_contents($path, $content);
    echo "✅ Migration amal na: App/Migrations/$filename\n";
}

function generateViews($name) {
    $dir = __DIR__ . "/App/Views/$name";
    if (!is_dir($dir)) mkdir($dir, 0777, true);
    $indexView = $dir . "/index.madeline.php";
    $viewContent = "@indi('layout')\n\n@def('content')\n<div class='container mx-auto p-4'>\n    <h1>Mboloo $name</h1>\n</div>\n@jeexdef";
    if (!file_exists($indexView)) {
        file_put_contents($indexView, $viewContent);
        echo "✅ Vue amal na: App/Views/$name/index.madeline.php\n";
    }
}

function installJsPlugin($pluginContext) {
    $plugin = strtolower($pluginContext);
    $cdns = [
        'alpine' => '<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>',
        'vue' => '<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>',
        'htmx' => '<script src="https://unpkg.com/htmx.org@1.9.10"></script>',
        'sweetalert2' => '<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>',
    ];
    if (!isset($cdns[$plugin])) { echo "❌ Librairie xamou ko. Options: alpine, vue, htmx, sweetalert2.\n"; return; }
    $layoutPath = __DIR__ . '/App/Views/layout.madeline.php';
    if (file_exists($layoutPath)) {
        $content = file_get_contents($layoutPath);
        if (strpos($content, $plugin) === false) {
            $content = str_replace('</head>', "    " . $cdns[$plugin] . "\n</head>", $content);
            file_put_contents($layoutPath, $content);
            echo "✅ $plugin tahl na ci sa layout !\n";
        } else { echo "⚠️  $plugin am na ba pare.\n"; }
    }
}

