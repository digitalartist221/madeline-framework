function installJsPlugin($pluginContext) {
    $plugin = strtolower($pluginContext);
    $cdns = [
        'alpine' => '<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>',
        'vue' => '<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>',
        'htmx' => '<script src="https://unpkg.com/htmx.org@1.9.10"></script>',
        'sweetalert2' => '<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>',
    ];
    if (!isset($cdns[$plugin])) { echo "❌ Librairie xamou ko. Options: alpine, vue, htmx, sweetalert2.\n"; return; }
    $layoutPath = __DIR__ . '/App/Views/layout.madeline.php';
    if (file_exists($layoutPath)) {
        $content = file_get_contents($layoutPath);
        if (strpos($content, $plugin) === false) {
            $content = str_replace('</head>', "    " . $cdns[$plugin] . "\n</head>", $content);
            file_put_contents($layoutPath, $content);
            echo "✅ $plugin tahl na ci sa layout !\n";
        } else { echo "⚠️  $plugin am na ba pare.\n"; }
    }
}

function linkStorage() {
    $target = __DIR__ . '/storage/app/public';
    $link = __DIR__ . '/public/storage';
    if (!is_dir($target)) mkdir($target, 0777, true);
    if (file_exists($link)) { echo "⚠️  Lien bi am na ba pare.\n"; return; }
    if (PHP_OS_FAMILY === 'Windows') {
        $target = str_replace('/', '\\', $target);
        $link = str_replace('/', '\\', $link);
        exec('mklink /D "' . $link . '" "' . $target . '"', $output, $resultCode);
        if ($resultCode === 0 || @symlink($target, $link)) { echo "✓ Storage takoo na ak public bi.\n"; }
        else { echo "❌ Jafe-jafe am na guirr takoo bi.\n"; }
    } else {
        if (@symlink($target, $link)) { echo "✓ Storage takoo na ak public bi.\n"; }
        else { echo "❌ Jafe-jafe am na guirr takoo bi.\n"; }
    }
}
