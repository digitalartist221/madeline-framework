#!/usr/bin/env php
<?php
/**
 * Madeline Framework - Ligeey CLI
 * Version: 1.0.0 Stable (Wolofized)
 */

if (php_sapi_name() !== 'cli') {
    die("Ligeey doit être exécuté en ligne de commande.");
}

require_once __DIR__ . '/Core/App.php';

// Auto-chargement basique des classes
spl_autoload_register(function ($class) {
    $classFile = str_replace('\\', '/', $class) . '.php';
    if (file_exists(__DIR__ . '/' . $classFile)) {
        require_once __DIR__ . '/' . $classFile;
    }
});

if ($argc < 2) {
    showHelp();
    exit(1);
}

$command = $argv[1];
$arg = $argv[2] ?? null;

switch ($command) {
    case 'amal:controller':
        if (!$arg) die("❌ Erreur: Dimbeuleul ma ak tourou Controller (ex: UserController).\n");
        generateController($arg);
        break;

    case 'amal:model':
        if (!$arg) die("❌ Erreur: Dimbeuleul ma ak tourou Model (ex: User).\n");
        generateModel($arg);
        break;
        
    case 'amal:migration':
        if (!$arg) die("❌ Erreur: Dimbeuleul ma ak tourou Migration (ex: create_users_table).\n");
        generateMigration($arg);
        break;

    case 'amal:crud':
        if (!$arg) die("❌ Erreur: Dimbeuleul ma ak tourou Entité (ex: User).\n");
        generateModel($arg);
        generateController("{$arg}Controller");
        generateViews(strtolower($arg));
        echo "✓ Madeline amal na sa MVC '$arg' ak mboloo mu mat sëkk.\n";
        break;

    case 'yoon:run':
    case 'migrate':
        require_once __DIR__ . '/Packages/ORM/Blueprint.php';
        require_once __DIR__ . '/Packages/ORM/Migrator.php';
        \Core\Config::load();
        $dbConfig = \Core\Config::get('database');
        if (empty($dbConfig['name']) && !file_exists(__DIR__ . '/config.php')) {
            die("❌ Erreur: Base de données configurer wul. Demal ci /setup.\n");
        }
        try {
            $dsn = "mysql:host={$dbConfig['host']};dbname={$dbConfig['name']};charset={$dbConfig['charset']}";
            $db = new \PDO($dsn, $dbConfig['user'], $dbConfig['pass'], [\PDO::ATTR_ERRMODE => \PDO::ERRMODE_EXCEPTION]);
            $migrator = new \Packages\ORM\Migrator($db);
            $migrator->migrate();
            echo "✓ Yoon yi dox nañu guirr sa base de données.\n";
        } catch (\PDOException $e) {
            die("❌ Ndiagum DB am na jafe-jafe : " . $e->getMessage() . "\n");
        }
        break;

    case 'tahl:auth':
    case 'install:auth':
        echo "⏳ Tahl bi pack d'authentification bi...\n";
        \Packages\Auth\AuthScaffold::install(__DIR__);
        echo "✓ Auths installés avec succès.\n";
        break;

    case 'far:auth':
    case 'remove:auth':
        echo "⏳ Far bi pack d'authentification bi...\n";
        \Packages\Auth\AuthScaffold::uninstall(__DIR__);
        echo "✓ Auths supprimés proprement.\n";
        break;

    case 'amal:user':
        if ($argc < 5) die("❌ Erreur: Utilisation: php ligeey amal:user [nom] [email] [password]\n");
        $name = $argv[2];
        $email = $argv[3];
        $pass = password_hash($argv[4], PASSWORD_DEFAULT);
        require_once __DIR__ . '/App/Models/User.php';
        $user = new \App\Models\User();
        $user->name = $name;
        $user->email = $email;
        $user->password = $pass;
        $user->bindu();
        echo "✓ Utilisateur '$name' ($email) créé avec succès.\n";
        break;

    case 'auth:check':
        $hasController = file_exists(__DIR__ . '/App/Controllers/AuthController.php');
        $hasModel = file_exists(__DIR__ . '/App/Models/User.php');
        echo "🔍 Vérification de l'Auth Madeline :\n";
        echo ($hasController ? "✅ Controller présent\n" : "❌ Controller absent\n");
        echo ($hasModel ? "✅ Modèle User présent\n" : "❌ Modèle User absent\n");
        break;

    case 'setal:cache':
    case 'cache:clear':
        echo "⏳ Setal bi caches yi...\n";
        $cacheDir = __DIR__ . '/storage/cache/views';
        if (is_dir($cacheDir)) {
            $files = glob($cacheDir . '/*.php');
            foreach ($files as $file) { if (is_file($file)) unlink($file); }
            echo "✓ Cache des vues setal na.\n";
        }
        break;

    case 'tahl:js':
    case 'install:js':
        if (!$arg) die("❌ Erreur: Spécifiez la librairie JS (alpine, vue, htmx, sweetalert2).\n");
        installJsPlugin($arg);
        break;

    case 'takoo:storage':
    case 'storage:link':
        linkStorage();
        break;

    case 'setal:reset':
    case 'reset:factory':
        echo "🚨 ATTENTION : Cette action va réinitialiser Madeline à zéro (fichiers originaux uniquement).\n";
        echo "🤔 Êtes-vous sûr ? (oui/non) : ";
        $handle = fopen("php://stdin", "r");
        $line = fgets($handle);
        if (trim($line) != 'oui') {
            echo "❌ Annulé.\n";
            exit;
        }
        echo "⏳ Réinitialisation en cours...\n";
        
        // 1. Nettoyage des dossiers
        $dirsToClean = [
            __DIR__ . '/App/Controllers',
            __DIR__ . '/App/Models',
            __DIR__ . '/App/Views',
            __DIR__ . '/App/Migrations',
            __DIR__ . '/storage/cache/views',
            __DIR__ . '/storage/app/public'
        ];

        $keepFiles = [
            'AuthController.php', 'DashboardController.php', 'DevController.php',
            'DocsController.php', 'PaytechController.php',
            'User.php', 
            'auth', 'docs', 'mail', 'errors', 'Components',
            'layout.madeline.php', 'dashboard.madeline.php', 'welcome.madeline.php',
            'api.madeline.php', 'guide.madeline.php' // Protecting doc views specifically
        ];

        foreach ($dirsToClean as $dir) {
            if (!is_dir($dir)) continue;
            $items = scandir($dir);
            foreach ($items as $item) {
                if ($item == '.' || $item == '..') continue;
                if (in_array($item, $keepFiles)) continue;
                
                $path = $dir . '/' . $item;
                if (is_dir($path)) {
                    // Simple recursive rmdir (minimal)
                    exec(PHP_OS_FAMILY === 'Windows' ? "rd /s /q \"$path\"" : "rm -rf \"$path\"");
                } else {
                    unlink($path);
                }
            }
        }

        // 2. Nettoyage de la base de données (si configurée)
        try {
            \Core\Config::load();
            $dbConfig = \Core\Config::get('database');
            if (!empty($dbConfig['name'])) {
                $dsn = "mysql:host={$dbConfig['host']};dbname={$dbConfig['name']};charset={$dbConfig['charset']}";
                $db = new \PDO($dsn, $dbConfig['user'], $dbConfig['pass']);
                $db->exec("SET FOREIGN_KEY_CHECKS = 0;");
                $tables = $db->query("SHOW TABLES")->fetchAll(\PDO::FETCH_COLUMN);
                foreach ($tables as $table) {
                    $db->exec("DROP TABLE `$table` ");
                }
                $db->exec("SET FOREIGN_KEY_CHECKS = 1;");
                echo "✓ Base de données nettoyée.\n";
            }
        } catch (\Exception $e) { echo "⚠️ DB non nettoyée : " . $e->getMessage() . "\n"; }

        // 3. Restauration des Templates "Indestructibles"
