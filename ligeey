    if (!is_dir($target)) mkdir($target, 0777, true);
    if (file_exists($link)) { echo "⚠️  Lien bi am na ba pare.\n"; return; }
    if (PHP_OS_FAMILY === 'Windows') {
        $target = str_replace('/', '\\', $target);
        $link = str_replace('/', '\\', $link);
        exec('mklink /D "' . $link . '" "' . $target . '"', $output, $resultCode);
        if ($resultCode === 0 || @symlink($target, $link)) { echo "✓ Storage takoo na ak public bi.\n"; }
        else { echo "❌ Jafe-jafe am na guirr takoo bi.\n"; }
    } else {
        if (@symlink($target, $link)) { echo "✓ Storage takoo na ak public bi.\n"; }
        else { echo "❌ Jafe-jafe am na guirr takoo bi.\n"; }
    }
}
