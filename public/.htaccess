# Madeline Public - Isolation Totale
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Ne rien faire si c'est un fichier ou dossier réel
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Envoyer tout vers index.php (url=...)
    # On évite RewriteBase pour rester porteur n'importe où
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>
